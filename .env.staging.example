# Copiar a .env en el servidor staging o cargar desde el proveedor de secrets.
# No commitear secretos reales.

NODE_ENV=production
PORT=5000
USE_POSTGRES_ONLY=true

# PostgreSQL (Neon: usar connection string del pooler)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# App
JWT_SECRET=change-me-min-32-chars-staging-only
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRES=7d
PG_POOL_MAX=20

# Front staging (CORS)
FRONTEND_URL=https://staging.tu-dominio.com
CORS_ORIGINS=https://staging.tu-dominio.com

# OpenAI (opcional en staging)
OPENAI_API_KEY=

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Health ampliado: GET /api/health?deep=1 con header x-health-secret
HEALTH_INTERNAL_SECRET=change-me-health-staging

# Webhooks n8n: obligatorio en producción salvo:
# REQUIRE_WEBHOOK_SECRET_IN_PRODUCTION=false
N8N_WEBHOOK_SECRET=

# Socket multi-réplica
# REDIS_URL=redis://default:pass@host:6379

# Carga / k6 desde una sola IP: permite desactivar rate limit de login/register/refresh
# SOLO staging + pruebas controladas. Nunca en producción real.
# LOAD_TEST_DISABLE_AUTH_RATE_LIMIT=true

# Playwright E2E contra URL del front o API desplegada:
# PLAYWRIGHT_BASE_URL=https://staging.tu-dominio.com npm run test:e2e:piloto
